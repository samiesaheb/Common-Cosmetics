<% if notification.notifiable&.respond_to?(:post) && notification.notifiable.post.present? %>
  <%= turbo_frame_tag dom_id(notification) do %>
    <%= link_to post_path(notification.notifiable.post, notification_id: notification.id), data: { turbo_frame: "_top" }, class: "block" do %>
      <div class="p-3 hover:bg-gray-100 dark:hover:bg-gray-700 <%= 'opacity-50' if notification.read_at %>">
        <p class="text-sm text-gray-900 dark:text-white">
          <strong>
            <% if notification.actor.present? %>
              <%= link_to notification.actor.username, user_path(notification.actor), class: "hover:underline text-primary" %>
            <% else %>
              [deleted user]
            <% end %>
          </strong>
          <%= notification.action %> in your post.
        </p>
      </div>
    <% end %>
  <% end %>
<% end %>
