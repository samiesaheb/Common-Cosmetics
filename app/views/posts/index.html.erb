<h1 class="text-2xl font-bold mb-6">🧴 Recent Posts</h1>

<%= link_to "➕ New Post", new_post_path, class: "bg-primary text-white px-4 py-2 rounded mb-6 inline-block" %>

<% if @posts.any? %>
  <div class="flex flex-col gap-6 w-full">
    <% @posts.each do |post| %>
      <div class="border rounded shadow-sm bg-white dark:bg-gray-900 p-4">
        <!-- 👤 Username + Rating -->
        <div class="flex justify-between text-sm text-gray-600 dark:text-gray-300">
          <span>
            👤 <%= link_to post.user.username, user_path(post.user), class: "hover:underline text-primary" %>
          </span>
          <span>⭐ <%= post.rating %>/5</span>
        </div>

        <!-- ✏️ Caption -->
        <p class="mt-2 text-sm text-gray-900 dark:text-gray-100"><%= truncate(parse_mentions_to_links(post.caption), length: 100) %></p>

        <!-- 🖼️ Image -->
        <% if post.image.attached? %>
          <%= link_to image_tag(post.image.variant(resize_to_limit: [600, 400]), class: "rounded mt-2 w-full object-cover"), post_path(post) %>
        <% else %>
          <%= link_to "View Post", post_path(post), class: "text-primary hover:underline block mt-2" %>
        <% end %>

        <!-- ❤️ Like -->
        <% if user_signed_in? %>
          <%= turbo_frame_tag "like_post_#{post.id}" do %>
            <div class="mt-4 flex items-center gap-3 text-sm">
              <% if post.likes.exists?(user: current_user) %>
                <%= button_to "💔 Unlike", post_like_path(post), method: :delete, data: { turbo_frame: "like_post_#{post.id}" }, class: "text-red-600 hover:underline" %>
              <% else %>
                <%= button_to "❤️ Like", post_like_path(post), method: :post, data: { turbo_frame: "like_post_#{post.id}" }, class: "text-gray-700 hover:underline" %>
              <% end %>
              <span class="text-gray-500"><%= post.likes.count %> likes</span>
            </div>
          <% end %>
        <% end %>

        <!-- 💬 Comments -->
        <div class="mt-4">
          <%= turbo_frame_tag "comments_post_#{post.id}" do %>
            <%= render partial: "comments/preview", locals: { post: post, limit: 2 } %>
          <% end %>
        </div>

        <!-- ✍️ Comment Form -->
        <% if user_signed_in? %>
          <div class="mt-4">
            <%= render partial: "comments/form", locals: { post: post, comment: post.comments.build } %>
          </div>
        <% end %>

        <!-- ✏️ Edit/Delete -->
        <% if post.user == current_user %>
          <div class="mt-4 flex gap-3 text-sm">
            <%= link_to "✏️ Edit", edit_post_path(post), class: "text-blue-600 hover:underline" %>
            <%= button_to '🗑️ Delete', post_path(post), method: :delete,
                  data: { confirm: 'Are you sure?' },
                  class: "text-red-600 hover:underline bg-transparent border-none" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No posts yet. <%= link_to "Create one?", new_post_path, class: "text-primary hover:underline" %></p>
<% end %>
