<%= turbo_stream.append "posts_list" do %>
  <%= render partial: "posts/post", collection: @posts, as: :post %>

  <% if @posts.next_page %>
    <%= turbo_stream.append "posts_list" do %>
      <%= link_to "Load More", more_posts_path(page: @posts.next_page),
                  data: { turbo_frame: "posts_list" },
                  class: "block mt-6 text-sm text-center text-primary hover:underline" %>
    <% end %>
  <% end %>
<% end %>
