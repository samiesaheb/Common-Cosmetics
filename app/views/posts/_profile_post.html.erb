<!-- posts/_profile_post.html.erb -->
<div class="bg-gray-900 border border-gray-800 rounded-lg p-4 space-y-3">
  <!-- 👤 Avatar + Username -->
  <div class="flex items-center gap-2 text-sm text-gray-400">
    <% if post.user.avatar.attached? %>
      <%= image_tag post.user.avatar.variant(resize_to_fill: [24, 24]), class: "w-6 h-6 rounded-full object-cover" %>
    <% else %>
      <div class="w-6 h-6 rounded-full bg-gray-700 flex items-center justify-center text-xs text-gray-400">👤</div>
    <% end %>
    <%= link_to post.user.username, user_path(post.user), class: "hover:underline" %>
  </div>

  <!-- ✏️ Caption -->
  <p class="text-sm text-gray-100"><%= parse_mentions_to_links(post.caption) %></p>

  <!-- ⭐ Star Rating -->
  <div class="flex items-center text-yellow-400 text-sm mt-1">
    <% 5.times do |i| %>
      <% if i < post.rating %>
        <span>★</span>
      <% else %>
        <span class="text-gray-600 dark:text-gray-700">☆</span>
      <% end %>
    <% end %>
  </div>

  <!-- 🖼️ Image -->
  <% if post.image.attached? %>
    <%= image_tag post.image.variant(resize_to_limit: [500, 500]),
          class: "rounded-lg max-w-full mx-auto object-cover border border-gray-800" %>
  <% end %>

  <!-- 💬 Comment Count -->
  <p class="text-sm text-gray-400 mt-2">
    💬 <%= pluralize(post.comments.count, "comment") %>
  </p>

  <!-- 💬 Comments Preview + Form (Turbo Frame!) -->
  <%= turbo_frame_tag "comments_post_#{post.id}" do %>
    <%= render partial: "comments/preview", locals: { post: post, limit: 2 } %>
    <%= render partial: "comments/form", locals: { post: post, comment: post.comments.build } %>
  <% end %>
</div>
