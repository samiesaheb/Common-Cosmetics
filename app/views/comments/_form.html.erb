<%= turbo_frame_tag "new_comment_post_#{post.id}" do %>
  <%= form_with(model: [post, comment], data: { turbo_frame: "new_comment_post_#{post.id}" }, local: true, class: "space-y-2") do |f| %>
    <%= f.hidden_field :parent_id %>

    <div>
      <%= f.text_area :body,
                      rows: 2,
                      required: true,
                      autocomplete: "off",
                      placeholder: "Write a comment...",
                      class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.submit "Comment", class: "bg-primary text-white px-3 py-1 rounded text-sm" %>
    </div>
  <% end %>
<% end %>
