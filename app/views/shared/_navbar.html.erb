<nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-black border-b border-gray-200 dark:border-gray-800 shadow-sm">
  <div class="w-full px-4 py-3 flex justify-between items-center">
    <!-- 🌐 Brand -->
    <div>
      <%= link_to "Common Cosmetics", root_path, class: "text-xl font-bold text-primary hover:underline" %>
    </div>

    <!-- 🌐 Links -->
    <div class="flex items-center space-x-4">
      <% if user_signed_in? %>
        <%= link_to "Home", posts_path, class: "text-gray-700 dark:text-gray-200 hover:underline" %>
        <%= link_to "Profile", user_path(current_user), class: "text-gray-700 dark:text-gray-200 hover:underline" %>
        <%= link_to "New Post", new_post_path, class: "text-gray-700 dark:text-gray-200 hover:underline" %>
        
        <!-- 🔔 Notifications -->
        <div x-data="{ open: false }" class="relative">
          <button @click="open = !open" class="relative p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800">
            🔔
            <%= render "notifications/count" %>
          </button>

          <div
            x-show="open"
            @click.outside="open = false"
            x-cloak
            class="absolute right-0 mt-2 w-80 max-h-96 overflow-y-auto bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg z-40"
          >
            <div id="notifications" class="divide-y divide-gray-100 dark:divide-gray-700">
              <%= render partial: "notifications/notification", collection: current_user.notifications.order(created_at: :desc).limit(10) %>
            </div>

            <div class="text-center py-2 border-t dark:border-gray-700">
              <%= button_to "Mark all as read", mark_all_as_read_notifications_path,
                  method: :post,
                  data: { turbo_stream: true },
                  class: "text-sm text-blue-600 hover:underline w-full text-left px-4 py-2" %>
            </div>

            <div class="text-center py-2 border-t dark:border-gray-700">
              <%= link_to "View All", notifications_path, class: "text-sm text-blue-600 hover:underline" %>
            </div>
          </div>
        </div>

        <!-- 👤 Avatar -->
        <div x-data="{ open: false }" class="relative">
          <button @click="open = !open" class="w-8 h-8 rounded-full overflow-hidden border-2 border-gray-300 dark:border-gray-700">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar.variant(resize_to_fill: [32, 32]), class: "w-8 h-8 object-cover" %>
            <% else %>
              <div class="w-8 h-8 bg-gray-200 dark:bg-gray-600 flex items-center justify-center text-sm text-gray-600 dark:text-gray-300">👤</div>
            <% end %>
          </button>

          <div
            x-show="open"
            @click.outside="open = false"
            x-cloak
            class="absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg z-40"
          >
            <%= link_to "Profile", edit_user_registration_path,
                class: "block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700" %>

            <%= link_to "Logout", destroy_user_session_path,
                method: :delete,
                data: { turbo_method: :delete },
                class: "block px-4 py-2 text-sm text-red-600 hover:bg-gray-100 dark:hover:bg-gray-700" %>
          </div>
        </div>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "text-gray-700 dark:text-gray-200 hover:underline" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "text-primary font-semibold hover:underline" %>
      <% end %>
    </div>
  </div>
</nav>
