<h2 class="text-2xl font-bold mb-6 text-center">Edit Profile</h2>

<%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }, class: "space-y-6") do |f| %>
  <!-- Avatar Upload -->
  <div>
    <%= f.label :avatar, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.file_field :avatar, direct_upload: true, class: "mt-1 block w-full text-sm text-gray-900 dark:text-gray-100" %>
    <% if resource.avatar.attached? %>
      <div class="mt-2">
        <%= image_tag resource.avatar.variant(resize_to_fill: [80, 80]), class: "w-20 h-20 rounded-full object-cover" %>
      </div>
    <% end %>
  </div>

  <div>
    <%= f.label :username, class: "block text-sm font-medium" %>
    <%= f.text_field :username, class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :bio, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.text_area :bio, rows: 3, class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">Share something about yourself.</p>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium" %>
    <%= f.email_field :email, class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2", autocomplete: "email" %>
  </div>

  <hr class="my-4 border-gray-300">

  <div>
    <%= f.label :password, "New password", class: "block text-sm font-medium" %>
    <%= f.password_field :password, autocomplete: "new-password", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">Leave blank if you don't want to change it.</p>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :current_password, "Current password", class: "block text-sm font-medium" %>
    <%= f.password_field :current_password, autocomplete: "current-password", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
    <p class="text-xs text-gray-500 mt-1">We need your current password to confirm your changes.</p>
  </div>

  <div>
    <%= f.submit "Update", class: "bg-primary text-white px-4 py-2 rounded w-full" %>
  </div>
<% end %>

<hr class="my-8 border-gray-300">

<h3 class="text-lg font-semibold mb-4 text-red-600">Cancel my account</h3>

<%= button_to "Cancel my account",
              registration_path(resource_name),
              method: :delete,
              data: { confirm: "Are you sure?" },
              class: "bg-red-600 text-white px-4 py-2 rounded" %>
