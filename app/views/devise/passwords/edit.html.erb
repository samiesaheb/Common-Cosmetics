<h2 class="text-2xl font-bold mb-6 text-center">Reset Password</h2>

<%= form_with(model: resource, as: resource_name, url: password_path(resource_name), method: :put, class: "space-y-4") do |f| %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, class: "block text-sm font-medium" %>
    <%= f.password_field :password, required: true, autocomplete: "new-password", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium" %>
    <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "mt-1 block w-full border border-gray-300 rounded px-3 py-2" %>
  </div>

  <div>
    <%= f.submit "Change my password", class: "bg-primary text-white px-4 py-2 rounded w-full" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
